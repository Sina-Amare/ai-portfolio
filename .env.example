# Copy to .env.local and fill in. All keys are server-side only — never exposed to the client.

# Google AI Studio key — embeddings (gemini-embedding-001) + chat (Gemini 2.5 Flash)
# Get one free (no card): https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenRouter key — chat fallback across free models
# Get one: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — Groq for ultra-fast streaming. https://console.groq.com/keys
# GROQ_API_KEY=

# Optional — Upstash Redis (REST) for distributed rate-limiting + answer cache. https://upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional — absolute site URL for metadata (production). Defaults to localhost in dev.
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional — override the RAG relevance gate (default 0.62). Lower = more permissive.
# RAG_THRESHOLD=0.62
