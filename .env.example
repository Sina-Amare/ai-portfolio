# Copy to .env.local and fill in. All keys are server-side only — never exposed to the client.

# Google AI Studio key — embeddings (gemini-embedding-001) + chat (Gemini 2.5 Flash)
# Get one free (no card): https://aistudio.google.com/app/apikey
# Tip: put SEVERAL keys comma-separated to multiply your quota — the chat ladder
# rotates across them and fails over when one is exhausted. e.g. KEY1,KEY2,KEY3
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq — fastest time-to-first-token, leads the chat ladder for English. Recommended.
# Get one free (no card): https://console.groq.com/keys  (also supports comma-separated keys)
GROQ_API_KEY=

# OpenRouter key — extra free-model fallback (also supports comma-separated keys)
# Get one: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Contact form → Telegram. Create a bot with @BotFather to get the token, then
# send the bot a message and read your numeric chat id from:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  (result[].message.chat.id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — Upstash Redis (REST). Powers the /admin visit analytics (and can later
# back distributed rate-limiting + the answer cache). Free tier: 256 MB, 500k commands
# per month, no credit card, and no idle pause. https://upstash.com
# Easiest path: Vercel dashboard → Storage → Marketplace → Upstash Redis, which injects
# both variables automatically. Without them the site runs fine; analytics just no-ops.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Password for the /admin analytics dashboard. Unset = the page stays locked and says so.
# This single shared secret is the whole auth boundary — use a long RANDOM value, not a
# memorable phrase.
# ADMIN_PASSWORD=
# Optional — signing key for the admin session cookie. When unset it is derived from
# ADMIN_PASSWORD via HKDF (never the password itself, so a leaked cookie can't be used to
# crack it); changing the password then also signs out existing sessions. Set an explicit
# value if you'd rather sessions survive a password change.
# ADMIN_SESSION_SECRET=

# Optional — abuse limits for the unauthenticated /api/track beacon. Defaults shown.
# ANALYTICS_RPM=20            # accepted beacons per IP per minute (shared across instances)
# ANALYTICS_DAILY_MAX=1200    # accepted beacons per day, protects the free Upstash quota
# ADMIN_LOGIN_MAX=10          # login attempts per IP per hour
# ADMIN_LOGIN_GLOBAL_MAX=60   # login attempts site-wide per hour

# Optional — canonical site URL for metadata / OG / sitemap. On Vercel this auto-resolves
# to your production deployment; set it explicitly once you point a custom domain.
# NEXT_PUBLIC_SITE_URL=https://sinaamareh.ir

# Optional — override the RAG relevance gate (default 0.60). Lower = more permissive.
# RAG_THRESHOLD=0.60
